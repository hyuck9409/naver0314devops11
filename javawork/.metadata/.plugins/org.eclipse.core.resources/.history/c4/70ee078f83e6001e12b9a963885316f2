package day0320;

import java.util.Scanner;

public class Ex10_ArraySearchStartsWith {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		Scanner sc=new Scanner(System.in)
				;
		String []members= {"강호동","한가인","유재석","이승민","강하나",
				"손미나","이영자","박남정","한지혜","손창민"};
		String input;
		/*
		 *  검색할 이름은? 강
		 *    1번째 : 강호동
		 *    5번째 : 강하나
		 *    총 2명 검색
		 *  검색할 이름은? 박이
		 *    "박이" 로 시작하는 멤버는 없습니다
		 *    
		 *  검색할 이름은? Q
		 *    ** 검색을 종료합니다 **  
		 */
		while(true)
			System.out.println("검색할 이름은?");
		Stirng input=sc.nextLine();		
		if(input.equalsIgnoreCase("Q"))
		{
			System.out.println("** 검색을 종료합니다 **");
			break;
		}
		
		int count=0;
		boolean found=false;
		for(int i=0;i<members.length;i++)
			if(members[i].startsWith(input))
			{
				count++;
				found=true;
				System.out.println((count == 1 ? "" : " ") + count + "번째 : " + members[i]);
			}
		
	
	if (!found) {
        System.out.println("\"" + input + "\" 로 시작하는 멤버는 없습니다");
    } else {
        System.out.println("총 " + count + "명 검색");
    }
	}
}
	


