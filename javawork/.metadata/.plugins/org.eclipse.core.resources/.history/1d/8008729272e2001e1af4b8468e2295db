package day0315;

public class Ex2_DataType {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
        //정수타입에 대하여 아라보자
		byte a=127;
		System.out.println(a);
		
		byte b=(byte) 200; //(byte) : cast연산자 : 강제로 형 변환, 값손실이 발생함
		System.out.println(b);//값손실이 발생할경우 엉뚱한 값이 출력(내부적으로는 2의 보수값이다) -56
		
		//실수 타입
		float f1=123.567891234f;//f 를 붙여야 4바이트 float으로 저장
		double f2=123.567891234;
		
		System.out.println(f1);
		System.out.println(f2);
	}

}
